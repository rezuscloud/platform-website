package sections

templ UseCases() {
	<section id="usecases" class="py-16 sm:py-24 bg-cream-50 dark:bg-terminal-bg">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl sm:text-4xl font-bold mb-4 font-display">What Will You Build?</h2>
				<p class="text-lg text-cream-600 dark:text-gray-400 max-w-2xl mx-auto font-display">
					Your own platform, your own rules. Here's some inspiration to get you started.
				</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
				@useCaseCard(
					"Home Server",
					"Run your own services at home — no subscriptions, no data leaving your network.",
					[]UseCaseItem{
						{"Media server", "Netflix, but yours"},
						{"File sync", "Dropbox, but private"},
						{"Home automation", "No cloud dependency"},
					},
					homeserverIcon(),
				)
				@useCaseCard(
					"Personal Projects",
					"Your side projects deserve production-grade infrastructure.",
					[]UseCaseItem{
						{"Website & blog hosting", "Your domain, your content"},
						{"Development environments", "Consistent and reproducible"},
						{"Portfolio & demos", "Always online, always yours"},
					},
					projectsIcon(),
				)
				@useCaseCard(
					"Private Cloud Storage",
					"Use cloud capacity with your own encryption — providers see nothing.",
					[]UseCaseItem{
						{"Encrypted backups", "Across multiple locations"},
						{"Photo storage", "Self-managed encryption keys"},
						{"Shared files", "Full privacy control"},
					},
					storageIcon(),
				)
			</div>
			<!-- People Are Building... -->
			<div class="mt-16 max-w-5xl mx-auto">
				<h3 class="text-2xl font-bold text-center mb-8 font-display">People Are Building...</h3>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
					@inspirationCard("Game servers for friends")
					@inspirationCard("Family photo gallery with AI tagging")
					@inspirationCard("Automated smart home")
					@inspirationCard("Personal finance tracker")
					@inspirationCard("Learning Kubernetes hands-on")
					@inspirationCard("Self-hosted email")
				</div>
			</div>
		</div>
	</section>
}

type UseCaseItem struct {
	Title       string
	Description string
}

templ useCaseCard(title string, description string, items []UseCaseItem, icon templ.Component) {
	<div class="bg-cream-100 dark:bg-terminal-surface rounded-xl p-6 border border-cream-300 dark:border-terminal-border hover:border-amber-400 dark:hover:border-phosphor-500 transition-all">
		<div class="w-12 h-12 bg-amber-100 dark:bg-amber-900/30 rounded-xl flex items-center justify-center mb-4">
			@icon
		</div>
		<h3 class="text-xl font-bold mb-2 font-display">{ title }</h3>
		<p class="text-sm text-cream-600 dark:text-gray-400 mb-4 font-display">{ description }</p>
		<ul class="space-y-2">
			for _, item := range items {
				<li class="flex items-start gap-2 text-sm">
					<span class="mt-1.5 w-1.5 h-1.5 bg-amber-500 rounded-full shrink-0"></span>
					<span class="font-display"><span class="font-medium">{ item.Title }</span> <span class="text-cream-600 dark:text-gray-400">— { item.Description }</span></span>
				</li>
			}
		</ul>
	</div>
}

templ inspirationCard(label string) {
	<div class="bg-cream-100 dark:bg-terminal-surface rounded-lg p-4 border border-cream-300 dark:border-terminal-border font-display text-sm">
		<div class="flex items-center gap-2">
			<span class="w-1.5 h-1.5 bg-amber-500 rounded-full shrink-0"></span>
			<span>{ label }</span>
		</div>
	</div>
}

templ homeserverIcon() {
	<svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
		<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"></path>
	</svg>
}

templ projectsIcon() {
	<svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
		<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"></path>
	</svg>
}

templ storageIcon() {
	<svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
		<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"></path>
	</svg>
}
